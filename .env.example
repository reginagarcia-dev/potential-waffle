# Backend configurations
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/workout_tracker
JWT_SECRET=supersecretjwtkeychangeinproduction12345
JWT_REFRESH_SECRET=supersecretjwtrefreshkeychangeinproduction54321
FRONTEND_URL=http://localhost:5173

# Node Environment
NODE_ENV=development

# Sentry error tracking (optional — leave unset to disable)
SENTRY_DSN=

# Resend transactional email (optional — leave unset and emails log to the
# console instead of sending). Used for password-reset emails and contact
# form notifications.
RESEND_API_KEY=
# Must be a domain verified in your Resend dashboard, or sends will fail.
RESEND_FROM_EMAIL=ArqLift <noreply@yourdomain.com>
# Where contact form submissions are emailed. Leave unset and submissions
# just log to the server console instead.
FEEDBACK_EMAIL_TO=
